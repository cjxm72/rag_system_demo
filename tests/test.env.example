OPENAI_API_KEY=xx
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen3.5-122B-A10B

EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
OCR_MODEL=Qwen/Qwen3-VL-8B-Instruct

# 生产级存储（集成测试必需）
# 与本机 PostgreSQL（public）示例一致；亦可在项目根 .env 中用 POSTGRES_* 默认项
DATABASE_URL=postgresql+psycopg://postgres:localhost@127.0.0.1:5432/postgres
# 本机 Milvus（不用 Docker 时同样填写本机地址）
MILVUS_URI=http://127.0.0.1:19530
# 终端打印对话/回答摘要（需 pytest -s）
# RAG_TEST_PRINT_ANSWERS=1
# 可选：MILVUS_COLLECTION=rag_kb
