# 复制为 .env 后按需修改。应用启动时会自动加载项目根目录 .env。

# 方式一：完整连接串（优先）
# DATABASE_URL=postgresql+psycopg://postgres:localhost@127.0.0.1:5432/postgres

# 方式二：分项（未设置 DATABASE_URL 时使用；默认与本机 postgres / public 一致）
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=localhost
POSTGRES_DB=postgres

# Milvus（本机安装并启动 standalone，不用 Docker）
# 二选一：MILVUS_URI 或 MILVUS_HOST + MILVUS_PORT
MILVUS_URI=http://127.0.0.1:19530
# MILVUS_HOST=127.0.0.1
# MILVUS_PORT=19530
# MILVUS_COLLECTION=rag_kb
